<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:background="#fff"
    android:layout_height="match_parent"
    tools:context=".PlayActivity">



    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:id="@+id/fullScreenVideo"
        android:elevation="1dp"
        android:visibility="gone"
        />

    <com.pierfrancescosoffritti.androidyoutubeplayer.core.player.views.YouTubePlayerView
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="35dp"
        android:id="@+id/youtubePlayer"
        android:layout_width="match_parent"
        android:layout_height="250dp"/>


    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:id="@+id/box"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/youtubePlayer">



    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="30dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/youtubePlayer"
        android:paddingHorizontal="8dp"
        android:textColor="#000"
        android:fontFamily="@font/roboto_regular"
        android:textSize="24sp"
        android:id="@+id/videoTitleTV"
        />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="20dp"
        android:text="Sport related Video"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/videoTitleTV"
        android:paddingHorizontal="4dp"
        android:textColor="#000"
        android:textStyle="bold"
        android:gravity="start"
        android:textFontWeight="600"
        android:fontFamily= "sans-serif-medium"
        android:textSize="16sp"
        android:id="@+id/videoCategoryTV"
        />

    <androidx.recyclerview.widget.RecyclerView
        android:layout_width="match_parent"
        android:layout_height="395dp"
        app:layout_constraintTop_toBottomOf="@id/videoCategoryTV"
        android:padding="1dp"
        android:id="@+id/reyclcerCategory"
        />

    </androidx.constraintlayout.widget.ConstraintLayout>


</androidx.constraintlayout.widget.ConstraintLayout>